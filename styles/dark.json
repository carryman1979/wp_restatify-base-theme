{
  "$schema": "https://schemas.wp.org/wp/6.7/theme.json",
  "version": 3,
  "title": "Dark",
  "settings": {
    "color": {
      "palette": [
        {
          "slug": "primary",
          "color": "#60a5fa",
          "name": "Primary"
        },
        {
          "slug": "primary-hover",
          "color": "#93c5fd",
          "name": "Primary Hover"
        },
        {
          "slug": "secondary",
          "color": "#2dd4bf",
          "name": "Secondary"
        },
        {
          "slug": "secondary-hover",
          "color": "#5eead4",
          "name": "Secondary Hover"
        },
        {
          "slug": "background",
          "color": "#0b1221",
          "name": "Background"
        },
        {
          "slug": "text",
          "color": "#e2e8f0",
          "name": "Text"
        },
        {
          "slug": "black",
          "color": "#000000",
          "name": "Black"
        }
      ]
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--background)",
      "text": "var(--wp--preset--color--text)"
    },
    "elements": {
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--primary)",
          "text": "#ffffff"
        }
      }
    }
  }
}
