{
  "apiVersion": 2,
  "name": "restatify/testimonials",
  "title": "Testimonials Section",
  "category": "design",
  "icon": "format-quote",
  "description": "Client testimonials with person cards.",
  "keywords": ["testimonials", "quotes", "clients"],
  "version": "1.0.0",
  "textdomain": "restatify-base",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "attributes": {
    "backgroundImageEnabled": { "type": "boolean", "default": true },
    "backgroundImageUrl": { "type": "string", "default": "" },
    "overlayEnabled": { "type": "boolean", "default": false },
    "overlayColor": { "type": "string", "default": "#0b1221" },
    "overlayOpacity": { "type": "number", "default": 20 },
    "parallax": { "type": "boolean", "default": false },
    "fullscreen": { "type": "boolean", "default": false },
    "label": { "type": "string", "default": "CLIENT TESTIMONIALS" },
    "showLabel": { "type": "boolean", "default": true },
    "quote1": { "type": "string", "default": "Working with our business consultant transformed our strategy. We gained clear insights that directly increased our efficiency and revenue." },
    "showQuote1": { "type": "boolean", "default": true },
    "person1Name": { "type": "string", "default": "Emily Johnson" },
    "showPerson1Name": { "type": "boolean", "default": true },
    "person1Role": { "type": "string", "default": "CEO" },
    "showPerson1Role": { "type": "boolean", "default": true },
    "person1ImageUrl": { "type": "string", "default": "/wp-content/themes/wp_restatify-base-theme/assets/images/image8.webp" },
    "quote2": { "type": "string", "default": "Their guidance helped us navigate complex market challenges. The results were measurable, and our growth accelerated faster than expected." },
    "showQuote2": { "type": "boolean", "default": true },
    "person2Name": { "type": "string", "default": "Michael Lee" },
    "showPerson2Name": { "type": "boolean", "default": true },
    "person2Role": { "type": "string", "default": "Founder" },
    "showPerson2Role": { "type": "boolean", "default": true },
    "person2ImageUrl": { "type": "string", "default": "/wp-content/themes/wp_restatify-base-theme/assets/images/image13.webp" },
    "quote3": { "type": "string", "default": "From operational improvements to strategic planning, the consultant provided practical solutions that made a real impact on our daily operations." },
    "showQuote3": { "type": "boolean", "default": true },
    "person3Name": { "type": "string", "default": "Sofia Martinez" },
    "showPerson3Name": { "type": "boolean", "default": true },
    "person3Role": { "type": "string", "default": "Operations Director" },
    "showPerson3Role": { "type": "boolean", "default": true },
    "person3ImageUrl": { "type": "string", "default": "/wp-content/themes/wp_restatify-base-theme/assets/images/image1.webp" }
  }
}
