{
  "apiVersion": 2,
  "name": "restatify/studies",
  "title": "Studies Section",
  "category": "design",
  "icon": "index-card",
  "description": "Two-column studies section with cards and links.",
  "keywords": ["studies", "results", "business", "section"],
  "version": "1.0.0",
  "textdomain": "restatify-base",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "attributes": {
    "backgroundImageEnabled": { "type": "boolean", "default": true },
    "backgroundImageUrl": { "type": "string", "default": "" },
    "overlayEnabled": { "type": "boolean", "default": false },
    "overlayColor": { "type": "string", "default": "#0b1221" },
    "overlayOpacity": { "type": "number", "default": 20 },
    "parallax": { "type": "boolean", "default": false },
    "fullscreen": { "type": "boolean", "default": false },
    "heading": { "type": "string", "default": "Real Business Results Through Strategic Consulting" },
    "showHeading": { "type": "boolean", "default": true },
    "introText": { "type": "string", "default": "A Business Consultant provides expert guidance to help companies overcome challenges, optimize operations, and achieve sustainable growth. Through data-driven analysis, tailored strategies." },
    "showIntroText": { "type": "boolean", "default": true },
    "card1ImageUrl": { "type": "string", "default": "/wp-content/themes/wp_restatify-base-theme/assets/images/image5.webp" },
    "card1Title": { "type": "string", "default": "Operational Efficiency Improvement" },
    "showCard1Title": { "type": "boolean", "default": true },
    "card1Text": { "type": "string", "default": "A mid-sized manufacturing company struggled with rising costs and slow production cycles. The Business Consultant analyzed workflows, identified bottlenecks, and implemented process improvements." },
    "showCard1Text": { "type": "boolean", "default": true },
    "card1ButtonLabel": { "type": "string", "default": "Read more" },
    "showCard1ButtonLabel": { "type": "boolean", "default": true },
    "card1Url": { "type": "string", "default": "" },
    "card2ImageUrl": { "type": "string", "default": "/wp-content/themes/wp_restatify-base-theme/assets/images/image6.webp" },
    "card2Title": { "type": "string", "default": "Growth Strategy" },
    "showCard2Title": { "type": "boolean", "default": true },
    "card2Text": { "type": "string", "default": "A technology startup faced stagnant revenue and unclear market positioning. The Business Consultant developed a comprehensive growth strategy, refined the value proposition." },
    "showCard2Text": { "type": "boolean", "default": true },
    "card2ButtonLabel": { "type": "string", "default": "Read more" },
    "showCard2ButtonLabel": { "type": "boolean", "default": true },
    "card2Url": { "type": "string", "default": "" },
    "cardSurfaceColor": { "type": "string", "default": "" },
    "cardBorderColor": { "type": "string", "default": "" },
    "lineStartColor": { "type": "string", "default": "" },
    "lineEndColor": { "type": "string", "default": "" },
    "linkColor": { "type": "string", "default": "" },
    "linkHoverColor": { "type": "string", "default": "" }
  }
}
