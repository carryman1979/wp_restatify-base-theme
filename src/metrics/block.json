{
  "apiVersion": 2,
  "name": "restatify/metrics",
  "title": "Metrics Section",
  "category": "design",
  "icon": "chart-bar",
  "description": "Business impact numbers section.",
  "keywords": ["numbers", "metrics", "stats"],
  "version": "1.0.0",
  "textdomain": "restatify-base",
  "editorScript": "file:./index.js",
  "viewScript": "file:./view.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "attributes": {
    "backgroundImageEnabled": { "type": "boolean", "default": true },
    "backgroundImageUrl": { "type": "string", "default": "" },
    "overlayEnabled": { "type": "boolean", "default": false },
    "overlayColor": { "type": "string", "default": "#0b1221" },
    "overlayOpacity": { "type": "number", "default": 20 },
    "parallax": { "type": "boolean", "default": false },
    "fullscreen": { "type": "boolean", "default": false },
    "heading": { "type": "string", "default": "Turning Business Challenges" },
    "showHeading": { "type": "boolean", "default": true },
    "text": { "type": "string", "default": "A Business Consultant provides strategic insight, objective analysis, and practical solutions." },
    "showText": { "type": "boolean", "default": true },
    "animationMode": { "type": "string", "default": "count-up" },
    "animationDuration": { "type": "number", "default": 1500 },
    "m1Number": { "type": "string", "default": "+35%" },
    "m1Label": { "type": "string", "default": "Revenue Growth" },
    "m2Number": { "type": "string", "default": "−25%" },
    "m2Label": { "type": "string", "default": "Cost Reduction" },
    "m3Number": { "type": "string", "default": "+40%" },
    "m3Label": { "type": "string", "default": "Decision Speed" },
    "m4Number": { "type": "string", "default": "3×" },
    "m4Label": { "type": "string", "default": "Market Expansion" }
  }
}
