{
  "apiVersion": 2,
  "name": "restatify/hero",
  "title": "Hero Section",
  "category": "design",
  "icon": "cover",
  "description": "Ein flexibler Hero-Block mit Parallax, Fullscreen, Buttons usw.",
  "keywords": ["hero", "parallax", "fullscreen", "section"],
  "version": "1.0.0",
  "textdomain": "restatify-base",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "attributes": {
    "backgroundImageEnabled": { "type": "boolean", "default": true },
    "backgroundImageUrl": { "type": "string", "default": "" },
    "overlayEnabled": { "type": "boolean", "default": false },
    "overlayColor": { "type": "string", "default": "#0b1221" },
    "overlayOpacity": { "type": "number", "default": 40 },
    "parallax": { "type": "boolean", "default": false },
    "fullscreen": { "type": "boolean", "default": false },
    "tagline": { "type": "string", "default": "Build Better" },
    "showTagline": { "type": "boolean", "default": true },
    "heading": { "type": "string", "default": "Real Business Results Through Strategic Consulting" },
    "showHeading": { "type": "boolean", "default": true },
    "text": { "type": "string", "default": "A Business Consultant provides expert guidance to help companies overcome challenges, optimize operations, and achieve sustainable growth." },
    "showText": { "type": "boolean", "default": true },
    "btn1Label": { "type": "string", "default": "Start now" },
    "showBtn1": { "type": "boolean", "default": true },
    "btn1Url": { "type": "string", "default": "" },
    "btn2Label": { "type": "string", "default": "Learn more" },
    "showBtn2": { "type": "boolean", "default": true },
    "btn2Url": { "type": "string", "default": "" }
  },
  "example": {
    "attributes": {
      "tagline": "Build Better",
      "showTagline": true,
      "heading": "Hero Block Vorschau",
      "showHeading": true,
      "text": "Das ist die Vorschau im Block-Inserter.",
      "showText": true,
      "btn1Label": "Starten",
      "showBtn1": true,
      "btn1Url": "#",
      "btn2Label": "Mehr erfahren",
      "showBtn2": true,
      "btn2Url": "#",
      "backgroundImageEnabled": true,
      "backgroundImageUrl": "",
      "overlayEnabled": false,
      "overlayColor": "#0b1221",
      "overlayOpacity": 40,
      "parallax": false,
      "fullscreen": false
    }
  }
}
