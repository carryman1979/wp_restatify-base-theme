{
  "apiVersion": 2,
  "name": "restatify/services",
  "title": "Services Section",
  "category": "design",
  "icon": "screenoptions",
  "description": "Services section with image, headline, and service items.",
  "keywords": ["services", "business", "section"],
  "version": "1.0.0",
  "textdomain": "restatify-base",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "attributes": {
    "backgroundImageEnabled": { "type": "boolean", "default": true },
    "backgroundImageUrl": { "type": "string", "default": "" },
    "overlayEnabled": { "type": "boolean", "default": false },
    "overlayColor": { "type": "string", "default": "#0b1221" },
    "overlayOpacity": { "type": "number", "default": 20 },
    "parallax": { "type": "boolean", "default": false },
    "fullscreen": { "type": "boolean", "default": false },
    "label": { "type": "string", "default": "PROFESSIONAL SERVICES" },
    "showLabel": { "type": "boolean", "default": true },
    "heading": { "type": "string", "default": "Driving Sustainable Growth Through Strategic Business" },
    "showHeading": { "type": "boolean", "default": true },
    "item1Title": { "type": "string", "default": "Planning" },
    "showItem1Title": { "type": "boolean", "default": true },
    "item1Text": { "type": "string", "default": "Comprehensive assessment of business performance, market positioning, and competitive landscape." },
    "showItem1Text": { "type": "boolean", "default": true },
    "item2Title": { "type": "string", "default": "Optimization" },
    "showItem2Title": { "type": "boolean", "default": true },
    "item2Text": { "type": "string", "default": "Identification of inefficiencies within processes and workflows, followed by practical solutions that improve productivity." },
    "showItem2Text": { "type": "boolean", "default": true },
    "item3Title": { "type": "string", "default": "Management" },
    "showItem3Title": { "type": "boolean", "default": true },
    "item3Text": { "type": "string", "default": "Support through business transformation, scaling, or restructuring by aligning teams, processes, and leadership to ensure smooth." },
    "showItem3Text": { "type": "boolean", "default": true },
    "imageUrl": { "type": "string", "default": "/wp-content/themes/wp_restatify-base-theme/assets/images/image18.webp" },
    "ctaLabel": { "type": "string", "default": "About consultant" },
    "showCtaLabel": { "type": "boolean", "default": true },
    "ctaUrl": { "type": "string", "default": "" },
    "ctaLightNormalColor": { "type": "string", "default": "" },
    "ctaLightHighlightColor": { "type": "string", "default": "" },
    "ctaDarkNormalColor": { "type": "string", "default": "" },
    "ctaDarkHighlightColor": { "type": "string", "default": "" }
  },
  "example": {
    "attributes": {
      "backgroundImageEnabled": true,
      "backgroundImageUrl": "",
      "overlayEnabled": false,
      "overlayColor": "#0b1221",
      "overlayOpacity": 20,
      "parallax": false,
      "fullscreen": false,
      "label": "PROFESSIONAL SERVICES",
      "heading": "Driving Sustainable Growth Through Strategic Business",
      "item1Title": "Planning",
      "item2Title": "Optimization",
      "item3Title": "Management",
      "ctaLabel": "About consultant"
    }
  }
}
